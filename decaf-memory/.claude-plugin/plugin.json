{
  "name": "decaf-memory",
  "description": "Memory skills backed by erinra memory MCP server",
  "author": { "name": "Alphaleonis", "url": "https://github.com/alphaleonis" },
  "homepage": "https://github.com/alphaleonis/decaf-claude-config",
  "repository": "https://github.com/alphaleonis/decaf-claude-config",
  "license": "MIT",
  "keywords": ["claude-code", "memory", "erinra", "semantic-search", "hybrid-search"],
  "skills": "./skills",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.js"
          }
        ]
      }
    ]
  }
}
